# Postgres connection. Local dev defaults to the helper's PG container.
DATABASE_URL=postgresql://minerva:minerva@127.0.0.1:5544/minerva

# NextAuth required pair. Generate the secret with:
#   openssl rand -base64 32
AUTH_SECRET=

# Public URL of this app; used by NextAuth to build callback URLs.
# In dev: http://localhost:3000  In prod: https://minerva.thefarshad.com
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (separate from the SPA's; create a *new* Web client in
# Google Cloud Console with redirect URI:
#   https://<your domain>/api/auth/callback/google
# and locally add http://localhost:3000/api/auth/callback/google for
# `npm run dev`.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional — proxy URL for the v1 helper service so the new app
# can keep using yt-dlp / opendataloader-pdf without rewriting them.
HELPER_BASE_URL=http://127.0.0.1:8765
