# Local session log — never commit (see LOG.md header)
LOG.md

# Long-form roadmap stays local
ROADMAP.md

# LLM-agent working guide — private session journal, never commit
AGENT_GUIDE.md

# Local Claude Code config (subagents, project settings) — never commit
.claude/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Stale Next traces if anything ever runs Next from repo root
.next/

# Root-level npm artifacts — every package lives in web/. If you
# see node_modules or package.json at the repo root it's because
# someone ran `npm install` from the wrong directory; deleting
# them is safe. These three lines anchor with a leading slash so
# they only match the root, never web/node_modules/* (which is
# covered by web/.gitignore).
/node_modules/
/package.json
/package-lock.json

# Secrets — Minerva intentionally keeps no secrets in the repo,
# but ignore these defensively in case anything is ever pasted locally.
.env
.env.*
secrets.json
*.local.json
Class-plus-plus
